{
  "name": "fitness",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --d1=DB",
    "deploy": "wrangler pages deploy public",
    "db:migrate": "wrangler d1 execute fitness-db --remote --file=./schema.sql",
    "db:seed": "wrangler d1 execute fitness-db --remote --file=./seed-trainer.sql",
    "db:reset:local": "wrangler d1 execute fitness-db --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
